// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String     @id @default(uuid())
  name      String
  email     String     @unique
  role      String
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  userLeads UserLead[]
}

model Lead {
  id        String     @id @default(uuid())
  name      String
  address   String
  product   String
  phone     String
  notes     String?
  revenue   Float
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  userLeads UserLead[]
}

model UserLead {
  id           String     @id @default(uuid())
  idUser       String
  idLead       String
  idLeadStatus String
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  user         User       @relation(fields: [idUser], references: [id])
  lead         Lead       @relation(fields: [idLead], references: [id])
  leadStatus   LeadStatus @relation(fields: [idLeadStatus], references: [id])
}

model LeadStatus {
  id        String     @id @default(uuid())
  name      String     @unique
  userLeads UserLead[]
}
