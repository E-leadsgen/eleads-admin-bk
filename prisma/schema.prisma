generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum LeadStatus {
  completed
  in_progress
  pending
  cancel
  sale
}

model User {
  id        String     @id @default(uuid())
  name      String
  email     String     @unique
  idCompany String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  userLeads UserLead[]
}

model Lead {
  id        String     @id @default(uuid())
  name      String
  email     String?
  address   String
  product   String
  phone     String
  notes     String?
  status    LeadStatus @default(pending)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  userLeads UserLead[]
}

model UserLead {
  id        String   @id @default(uuid())
  idUser    String
  idLead    String
  revenue   Float    @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [idUser], references: [id])
  lead      Lead     @relation(fields: [idLead], references: [id])
}
